# Whoop Developer API — register at developer.whoop.com
VITE_WHOOP_CLIENT_ID=your_whoop_client_id_here

# Redirect URI must match what's registered in your Whoop app
# Local: http://localhost:8888/whoop/callback (netlify dev)
# Production: https://your-app.netlify.app/whoop/callback
VITE_WHOOP_REDIRECT_URI=http://localhost:8888/whoop/callback

# Server-side only — never expose in client code
WHOOP_CLIENT_SECRET=your_whoop_client_secret_here

# Pirate Weather API — get a free key at pirateweather.net (10k calls/month)
# Server-side only, no VITE_ prefix — set in Netlify UI
PIRATE_WEATHER_API_KEY=your_pirate_weather_api_key_here
